# =============================================================================
# Llama 3.1 Modelfile - 完整配置示例
# =============================================================================
# 基于 Meta Llama 3.1 架构的 Ollama 模型配置文件
# 支持版本: 8B, 70B, 405B (通过标签指定)
# 官方文档: https://docs.ollama.com/modelfile
# =============================================================================

# -----------------------------------------------------------------------------
# FROM (必需) - 指定基础模型
# -----------------------------------------------------------------------------
# 可用标签:
#   llama3.1          - 默认最新版 (通常为 8B)
#   llama3.1:8b       - 8B 参数版本 (约 4.7GB)
#   llama3.1:70b      - 70B 参数版本 (约 40GB)
#   llama3.1:405b     - 405B 参数版本 (约 230GB)
#   llama3.1:text     - 仅文本版本 (无对话能力)
# -----------------------------------------------------------------------------
FROM llama3.1:8b

# -----------------------------------------------------------------------------
# TEMPLATE - 对话模板 (Llama 3.1 特定格式)
# -----------------------------------------------------------------------------
# 使用 Llama 3.1 的原生对话格式:
#   - <|begin_of_text|> - 文本开始标记
#   - <|start_header_id|>...<|end_header_id|> - 角色头
#   - <|eot_id|> - 回合结束标记
# -----------------------------------------------------------------------------
TEMPLATE """{{ if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>{{ end }}{{ if .Prompt }}<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}<|eot_id|>{{ end }}<|start_header_id|>assistant<|end_header_id|>

{{ .Response }}<|eot_id|>"""

# -----------------------------------------------------------------------------
# SYSTEM - 系统提示词 (定义 AI 助手的行为和个性)
# -----------------------------------------------------------------------------
# 这是模型的"身份卡"，决定了它如何回应用户
# 可以根据具体用例自定义此部分
# -----------------------------------------------------------------------------
SYSTEM """You are a helpful, respectful, and honest assistant. Always answer as helpfully as possible, while being safe. Your answers should not include any harmful, unethical, racist, sexist, toxic, dangerous, or illegal content. Please ensure that your responses are socially unbiased and positive in nature.

If a question does not make any sense, or is not factually coherent, explain why instead of answering something not correct. If you don't know the answer to a question, please don't share false information."""

# =============================================================================
# PARAMETER - 模型运行参数配置
# =============================================================================

# -----------------------------------------------------------------------------
# 生成控制参数
# -----------------------------------------------------------------------------

# temperature: 控制输出的随机性/创造性
#   - 0.0-0.3: 更确定、连贯、适合代码/事实查询
#   - 0.4-0.7: 平衡模式 (推荐日常使用)
#   - 0.8-1.0: 更有创意、多样化、适合头脑风暴
PARAMETER temperature 0.7

# top_p: 核采样阈值，控制词汇选择的多样性
#   - 较低值 (如 0.1): 更保守、确定性输出
#   - 较高值 (如 0.9): 更多样化输出
#   - 建议与 temperature 配合使用
PARAMETER top_p 0.9

# top_k: 限制每次生成的候选词数量
#   - 40: 平衡质量和速度
#   - 较低值加快生成，较高值提高质量
PARAMETER top_k 40

# min_p: 最小概率阈值，过滤低概率 token
PARAMETER min_p 0.05

# -----------------------------------------------------------------------------
# 上下文和长度参数
# -----------------------------------------------------------------------------

# num_ctx: 上下文窗口大小 (以 token 计)
#   - 4096: 标准长度
#   - 8192: 长文档处理
#   - 128000: Llama 3.1 支持的最大上下文 (需要足够内存)
# 注意: 增大此值会显著增加内存使用
PARAMETER num_ctx 4096

# num_predict: 最大生成 token 数 (-1 = 无限制)
#   用于控制响应长度，防止过长输出
PARAMETER num_predict -1

# -----------------------------------------------------------------------------
# 重复和惩罚参数
# -----------------------------------------------------------------------------

# repeat_penalty: 重复惩罚系数
#   - 1.0: 无惩罚
#   - 1.1-1.2: 轻微惩罚重复 (推荐)
#   - >1.2: 强惩罚，可能导致输出不自然
PARAMETER repeat_penalty 1.1

# repeat_last_n: 检查重复的历史 token 数
PARAMETER repeat_last_n 64

# frequency_penalty: 基于出现频率的惩罚
PARAMETER frequency_penalty 0.0

# presence_penalty: 基于是否出现过的惩罚
PARAMETER presence_penalty 0.0

# -----------------------------------------------------------------------------
# 性能优化参数
# -----------------------------------------------------------------------------

# num_gpu: 加载到 GPU 的层数 (-1 = 自动/全部)
#   - -1: 自动决定 (推荐)
#   - 0: 仅 CPU 运行
#   - 正整数: 指定层数
PARAMETER num_gpu -1

# num_thread: CPU 推理线程数 (0 = 自动)
PARAMETER num_thread 0

# batch_size: 批处理大小 (影响生成速度)
PARAMETER batch_size 512

# -----------------------------------------------------------------------------
# 停止词/序列 (Stop Sequences)
# -----------------------------------------------------------------------------
# 当模型生成这些标记时停止生成
# 必须与 TEMPLATE 中使用的特殊 token 匹配
# -----------------------------------------------------------------------------
PARAMETER stop <|start_header_id|>
PARAMETER stop <|end_header_id|>
PARAMETER stop <|eot_id|>
PARAMETER stop <|reserved_special_token

# =============================================================================
# 可选高级配置
# =============================================================================

# -----------------------------------------------------------------------------
# LICENSE - 许可证信息 (可选)
# -----------------------------------------------------------------------------
LICENSE """LLAMA 3.1 COMMUNITY LICENSE AGREEMENT

Copyright (c) Meta Platforms, Inc. and affiliates.

This is the Llama 3.1 Community License Agreement. By using, copying, or distributing the Llama 3.1 model, you agree to be bound by the terms of this license."""

# -----------------------------------------------------------------------------
# MESSAGE - 预设对话历史 (可选)
# -----------------------------------------------------------------------------
# 用于 few-shot 学习，给模型提供示例对话
# 可以帮助模型理解期望的回应风格
# -----------------------------------------------------------------------------
# MESSAGE user "你好，请介绍一下自己"
# MESSAGE assistant "你好！我是基于 Llama 3.1 的 AI 助手。我可以帮助你回答问题、写作、编程、分析等各种任务。有什么我可以帮你的吗？"

# -----------------------------------------------------------------------------
# ADAPTER - LoRA 适配器 (可选，用于微调模型)
# -----------------------------------------------------------------------------
# 如果需要加载微调后的 LoRA 权重，取消下面注释并指定路径
# ADAPTER ./path/to/your/lora-adapter.safetensors

# =============================================================================
# 使用说明
# =============================================================================
# 1. 保存此文件为 "Modelfile"
# 2. 创建自定义模型:
#    ollama create my-llama3.1 -f Modelfile
# 3. 运行模型:
#    ollama run my-llama3.1
# 4. 查看模型信息:
#    ollama show my-llama3.1
# =============================================================================